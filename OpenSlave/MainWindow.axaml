<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenSlave.MainWindow"
        Title="OpenSlave — Modbus slave simulator"
        Icon="/Assets/icon.png"
        Width="900" Height="640"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">

        <!-- ════════ Brand bar ════════ -->
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="6" BorderThickness="1">
                        <Image Source="/Assets/icon.png" Width="18" Height="18" />
                    </Border>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="OPENSLAVE" FontWeight="Bold" FontSize="13" LetterSpacing="3" />
                        <TextBlock Text="Open-source Modbus slave simulator · v1" FontSize="10" Opacity="0.6" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════ Listen settings + start/stop ════════ -->
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Port:" VerticalAlignment="Center" />
                <NumericUpDown Name="PortInput" Minimum="1" Maximum="65535" Increment="1"
                               FormatString="0" Value="1502" Width="100" />
                <TextBlock Text="Unit ID:" VerticalAlignment="Center" Margin="12,0,0,0" />
                <NumericUpDown Name="UnitIdInput" Minimum="1" Maximum="247" Increment="1"
                               FormatString="0" Value="1" Width="80" />
                <Button Name="StartButton" Content="● Start" Click="OnStart" Margin="16,0,0,0" />
                <Button Name="StopButton" Content="Stop" Click="OnStop" IsEnabled="False" />
                <Border Name="StatusPill" CornerRadius="14" Padding="12,5" BorderThickness="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Name="StatusDot" Width="8" Height="8" Fill="#888" VerticalAlignment="Center" />
                        <TextBlock Name="StatusText" Text="Stopped" VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ════════ Tab strip: register tables + request log ════════ -->
        <TabControl DockPanel.Dock="Top" Name="MainTabs">
            <TabItem Header="Coils (0x)">
                <DataGrid Name="CoilsGrid" AutoGenerateColumns="False" SelectionMode="Single"
                          IsReadOnly="False" RowEditEnded="OnCoilEdit">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Address" Binding="{ReflectionBinding Address}" IsReadOnly="True" Width="100" />
                        <DataGridTextColumn Header="Value" Binding="{ReflectionBinding Display}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Discrete inputs (1x)">
                <DataGrid Name="DiscreteGrid" AutoGenerateColumns="False" SelectionMode="Single"
                          IsReadOnly="False" RowEditEnded="OnDiscreteEdit">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Address" Binding="{ReflectionBinding Address}" IsReadOnly="True" Width="100" />
                        <DataGridTextColumn Header="Value" Binding="{ReflectionBinding Display}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Holding registers (4x)">
                <DataGrid Name="HoldingGrid" AutoGenerateColumns="False" SelectionMode="Single"
                          IsReadOnly="False" RowEditEnded="OnHoldingEdit">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Address" Binding="{ReflectionBinding Address}" IsReadOnly="True" Width="100" />
                        <DataGridTextColumn Header="Value" Binding="{ReflectionBinding Display}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Input registers (3x)">
                <DataGrid Name="InputGrid" AutoGenerateColumns="False" SelectionMode="Single"
                          IsReadOnly="False" RowEditEnded="OnInputEdit">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Address" Binding="{ReflectionBinding Address}" IsReadOnly="True" Width="100" />
                        <DataGridTextColumn Header="Value" Binding="{ReflectionBinding Display}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Request log">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Clear" Click="OnClearLog" />
                            <CheckBox Name="AutoScrollInput" Content="Auto-scroll" IsChecked="True" />
                        </StackPanel>
                    </Border>
                    <ListBox Name="LogList" />
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- footer: counts -->
        <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" Padding="16,8">
            <TextBlock Name="StatsText" Text="—" FontSize="11" Opacity="0.7" />
        </Border>

    </DockPanel>
</Window>
