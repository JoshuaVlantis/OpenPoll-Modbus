<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OpenPoll.Views"
        x:Class="OpenPoll.Views.HomeView"
        Title="OpenPoll"
        Icon="/Assets/icon.png"
        Width="900" Height="640"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceBaseBrush}">

    <DockPanel LastChildFill="True">

        <!-- ════════ Brand bar ════════ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HeroGradientBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Menu Grid.Column="0" VerticalAlignment="Center">
                    <MenuItem Header="File">
                        <MenuItem Header="New poll" Click="OnNewTab" InputGesture="Ctrl+N" />
                        <MenuItem Header="Duplicate poll" Click="OnDuplicateTab" InputGesture="Ctrl+D" />
                        <MenuItem Header="Close poll" Click="OnCloseActive" InputGesture="Ctrl+W" />
                        <Separator />
                        <MenuItem Header="Open workspace…" Click="OnLoadWorkspace" InputGesture="Ctrl+O" />
                        <MenuItem Header="Save workspace…" Click="OnSaveWorkspace" InputGesture="Ctrl+S" />
                        <MenuItem x:Name="RecentMenu" Header="Recent workspaces" />
                        <Separator />
                        <MenuItem Header="Setup…" Click="OnOpenSetup" />
                        <MenuItem Header="Connection Setup…" Click="OnOpenConnectionSetup" />
                        <MenuItem Header="Colour Rules…" Click="OnOpenColourRules" />
                        <Separator />
                        <MenuItem Header="Manual write — Single Coil (FC 05)…"     Click="OnManualWrite05" InputGesture="F5" />
                        <MenuItem Header="Manual write — Single Register (FC 06)…" Click="OnManualWrite06" InputGesture="F6" />
                        <MenuItem Header="Manual write — Multi Coils (FC 15)…"     Click="OnManualWrite15" InputGesture="F7" />
                        <MenuItem Header="Manual write — Multi Registers (FC 16)…" Click="OnManualWrite16" InputGesture="F8" />
                        <Separator />
                        <MenuItem Header="Exit" Click="OnExit" />
                    </MenuItem>
                    <MenuItem Header="Tools">
                        <MenuItem Header="Modbus Scraper…" Click="OnOpenScraper" />
                        <MenuItem Header="Live Chart…" Click="OnOpenChart" />
                        <MenuItem Header="Traffic Monitor…" Click="OnOpenTrafficMonitor" />
                        <MenuItem Header="Read Device ID… (FC 43)" Click="OnOpenDeviceId" />
                        <MenuItem Header="Test Center… (raw PDU)" Click="OnOpenTestCenter" />
                        <Separator />
                        <MenuItem x:Name="CsvLogMenu" Header="Start CSV snapshot (1s)" Click="OnToggleCsvSnapshot" />
                        <MenuItem Header="Reveal log folder…" Click="OnRevealLogFolder" />
                        <Separator />
                        <MenuItem x:Name="HttpApiMenu" Header="Start HTTP API (:8080)" Click="OnToggleHttpApi" />
                    </MenuItem>
                </Menu>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="6"
                            Background="{DynamicResource AccentSurfaceBrush}"
                            BorderBrush="{DynamicResource AccentBorderBrush}"
                            BorderThickness="1">
                        <Image Source="/Assets/icon.png" Width="18" Height="18"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Spacing="0">
                        <TextBlock Text="OPENPOLL" FontWeight="Bold" FontSize="13"
                                   LetterSpacing="3" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Open-source Modbus client · v1" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,1,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Right column kept Auto and empty so the brand stays geometrically centered -->
                <Border Grid.Column="2" />
            </Grid>
        </Border>

        <!-- ════════ Tab strip ════════ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Surface1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <ScrollViewer Grid.Column="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl Name="TabStrip">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="tab" Tag="{Binding}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,0,1,0"
                                        Padding="14,8"
                                        PointerPressed="OnTabPressed">
                                    <Grid ColumnDefinitions="Auto,Auto" >
                                        <TextBlock Grid.Column="0"
                                                   Text="{ReflectionBinding Title}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   FontSize="12" />
                                        <Button Grid.Column="1"
                                                Content="×"
                                                Classes="ghost"
                                                Click="OnCloseTab"
                                                Tag="{Binding}"
                                                Padding="4,0" MinHeight="0" Margin="0"
                                                FontSize="14" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Button Grid.Column="1"
                        Content="+"
                        Classes="ghost"
                        Click="OnNewTab"
                        Padding="14,0"
                        MinHeight="32"
                        ToolTip.Tip="New poll (Ctrl+N)" />
            </Grid>
        </Border>

        <!-- ════════ Action bar ════════ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Surface1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Grid.Column="0" Name="ConnectButton" Content="● Connect"
                        Classes="primary" Click="OnConnect" Width="116" Margin="0,0,8,0" />
                <Button Grid.Column="1" Name="StopButton" Content="Stop"
                        Click="OnStop" Width="92" IsEnabled="False" />

                <Border Grid.Column="3"
                        Name="StatusPill"
                        Background="{DynamicResource StatusIdleSurfaceBrush}"
                        BorderBrush="{DynamicResource StatusIdleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12,5"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Name="StatusDot" Width="8" Height="8"
                                 Fill="{DynamicResource StatusIdleBrush}" VerticalAlignment="Center" />
                        <TextBlock Name="StatusText" Text="Disconnected"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ════════ Footer ════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource Surface1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Name="HintText"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Text="Right-click a value to change its data type · Double-click a Binary cell to bit-edit · Ctrl+N new tab" />

                <Border Grid.Column="1"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,3"
                        Background="{DynamicResource Surface2Brush}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="POLL" FontSize="9" FontWeight="Bold"
                                   LetterSpacing="2"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Name="PollCountText" Text="0"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ════════ Data card (active doc) ════════ -->
        <Border Margin="16,16,16,16"
                Background="{DynamicResource Surface1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Rectangle Width="2" Height="14" Fill="{DynamicResource AccentBrush}" />
                            <TextBlock Text="MODBUS DATA" FontSize="11" FontWeight="Bold"
                                       LetterSpacing="2.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Name="DataSubtitle"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Text="—" />
                    </Grid>
                </Border>

                <DataGrid Name="DataGrid"
                          Margin="0"
                          CanUserSortColumns="False"
                          CanUserReorderColumns="False"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          SelectionMode="Extended"
                          BeginningEdit="OnBeginningEdit"
                          RowEditEnded="OnRowEditEnded"
                          DoubleTapped="OnGridDoubleTapped">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FUNC"
                                            Binding="{ReflectionBinding Function}"
                                            IsReadOnly="True" Width="80"
                                            FontFamily="{DynamicResource SansFont}"
                                            FontSize="12" />
                        <DataGridTextColumn Header="ADDR"
                                            Binding="{ReflectionBinding DisplayAddress}"
                                            IsReadOnly="True" Width="100"
                                            FontFamily="{DynamicResource MonoFont}"
                                            Foreground="{DynamicResource TextSecondaryBrush}" />
                        <DataGridTemplateColumn Header="VALUE" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{ReflectionBinding Value}"
                                               FontFamily="{DynamicResource MonoFont}"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               Margin="12,0"
                                               Foreground="{ReflectionBinding ForegroundHex,
                                                            Converter={x:Static views:HexStringToBrushConverter.Instance}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{ReflectionBinding Value, Mode=TwoWay}"
                                             FontFamily="{DynamicResource MonoFont}"
                                             BorderThickness="0"
                                             Padding="12,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu Name="ValueContextMenu">
                            <MenuItem x:Name="MenuItem16BitHeader" Header="16-bit (1 reg)" IsEnabled="False" />
                            <MenuItem x:Name="MenuItemSigned"   Header="  Signed"   Click="OnTypeSigned" />
                            <MenuItem x:Name="MenuItemUnsigned" Header="  Unsigned" Click="OnTypeUnsigned" />
                            <MenuItem x:Name="MenuItemHex"      Header="  Hex"      Click="OnTypeHex" />
                            <MenuItem x:Name="MenuItemBinary"   Header="  Binary"   Click="OnTypeBinary" />
                            <Separator />
                            <MenuItem x:Name="MenuItem32BitHeader" Header="32-bit (2 regs)" IsEnabled="False" />
                            <MenuItem x:Name="MenuItemSigned32"   Header="  Signed 32"   Click="OnTypeSigned32" />
                            <MenuItem x:Name="MenuItemUnsigned32" Header="  Unsigned 32" Click="OnTypeUnsigned32" />
                            <MenuItem x:Name="MenuItemHex32"      Header="  Hex 32"      Click="OnTypeHex32" />
                            <MenuItem x:Name="MenuItemFloat"      Header="  Float (32)"  Click="OnTypeFloat" />
                            <Separator />
                            <MenuItem x:Name="MenuItem64BitHeader" Header="64-bit (4 regs)" IsEnabled="False" />
                            <MenuItem x:Name="MenuItemSigned64"   Header="  Signed 64"   Click="OnTypeSigned64" />
                            <MenuItem x:Name="MenuItemUnsigned64" Header="  Unsigned 64" Click="OnTypeUnsigned64" />
                            <MenuItem x:Name="MenuItemHex64"      Header="  Hex 64"      Click="OnTypeHex64" />
                            <MenuItem x:Name="MenuItemDouble"     Header="  Double (64)" Click="OnTypeDouble" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </DockPanel>
        </Border>

    </DockPanel>
</Window>
