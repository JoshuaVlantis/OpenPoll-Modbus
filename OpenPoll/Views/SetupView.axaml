<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenPoll.Views.SetupView"
        Title="Modbus Setup"
        Width="380" Height="340"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="140,*">

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Node ID" VerticalAlignment="Center" />
        <NumericUpDown Grid.Row="0" Grid.Column="1" Name="NodeIdInput"
                       Minimum="1" Maximum="247" Increment="1" FormatString="0" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Starting address" VerticalAlignment="Center" Margin="0,8,0,0" />
        <NumericUpDown Grid.Row="1" Grid.Column="1" Name="AddressInput"
                       Minimum="0" Maximum="65535" Increment="1" FormatString="0" Margin="0,8,0,0" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Amount" VerticalAlignment="Center" Margin="0,8,0,0" />
        <NumericUpDown Grid.Row="2" Grid.Column="1" Name="AmountInput"
                       Minimum="1" Maximum="125" Increment="1" FormatString="0" Margin="0,8,0,0" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Function" VerticalAlignment="Center" Margin="0,8,0,0" />
        <ComboBox Grid.Row="3" Grid.Column="1" Name="FunctionInput" Margin="0,8,0,0" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="0x — Coils" />
            <ComboBoxItem Content="1x — Discrete Inputs" />
            <ComboBoxItem Content="4x — Holding Registers" />
            <ComboBoxItem Content="3x — Input Registers" />
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Address base" VerticalAlignment="Center" Margin="0,8,0,0" />
        <ComboBox Grid.Row="4" Grid.Column="1" Name="AddressBaseInput" Margin="0,8,0,0" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="0-indexed (raw protocol)" />
            <ComboBoxItem Content="1-indexed (PLC display)" />
        </ComboBox>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Word order" VerticalAlignment="Center" Margin="0,8,0,0" />
        <ComboBox Grid.Row="5" Grid.Column="1" Name="WordOrderInput" Margin="0,8,0,0" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="ABCD — big-endian" />
            <ComboBoxItem Content="CDAB — word swap" />
            <ComboBoxItem Content="BADC — byte swap" />
            <ComboBoxItem Content="DCBA — word + byte swap" />
        </ComboBox>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="OnCancel" />
            <Button Content="Save" Click="OnSave" Classes="primary" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
