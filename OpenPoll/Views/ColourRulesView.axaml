<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenPoll.Views.ColourRulesView"
        Title="Colour Rules"
        Width="640" Height="440"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBaseBrush}">
    <DockPanel Margin="16">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Surface1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="RULES" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <Button Content="Add" Click="OnAdd" />
                <Button Content="Remove" Click="OnRemove" />
                <TextBlock Text="First match wins"
                           VerticalAlignment="Center" Margin="20,0,0,0"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontStyle="Italic" />
            </StackPanel>
        </Border>
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="OnCancel" />
                <Button Content="OK" Click="OnOk" Classes="primary" />
            </StackPanel>
        </Border>
        <DataGrid Name="Grid"
                  CanUserSortColumns="False"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="WHEN" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{ReflectionBinding Comparison}"
                                      Margin="4,2">
                                <ComboBoxItem Tag="Equal" Content="=" />
                                <ComboBoxItem Tag="NotEqual" Content="!=" />
                                <ComboBoxItem Tag="LessThan" Content="&lt;" />
                                <ComboBoxItem Tag="LessOrEqual" Content="&lt;=" />
                                <ComboBoxItem Tag="GreaterThan" Content="&gt;" />
                                <ComboBoxItem Tag="GreaterOrEqual" Content="&gt;=" />
                                <ComboBoxItem Tag="Between" Content="in [a..b]" />
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="VALUE A" Width="120"
                                    Binding="{ReflectionBinding Value}"
                                    FontFamily="{DynamicResource MonoFont}" />
                <DataGridTextColumn Header="VALUE B" Width="120"
                                    Binding="{ReflectionBinding Value2}"
                                    FontFamily="{DynamicResource MonoFont}" />
                <DataGridTextColumn Header="COLOUR (#RRGGBB)" Width="*"
                                    Binding="{ReflectionBinding ColourHex}"
                                    FontFamily="{DynamicResource MonoFont}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
